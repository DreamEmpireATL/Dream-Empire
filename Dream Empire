<!DOCTYPE html>
<html>
<head>
  <title>Dream Empire</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #000;
      color: #fff;
    }

    header {
      text-align: center;
      padding: 50px 20px;
      background: #ffd1dc;
      color: #000;
    }

    header h1 {
      margin: 0;
      font-size: 40px;
      letter-spacing: 2px;
    }

    section {
      padding: 50px 20px;
      text-align: center;
    }

    .box {
      background: #fff;
      color: #000;
      margin: 20px auto;
      padding: 30px;
      border-radius: 15px;
      max-width: 600px;
    }

    .btn {
      display: inline-block;
      margin: 10px;
      padding: 12px 25px;
      background: #ffd1dc;
      color: #000;
      text-decoration: none;
      border-radius: 25px;
      font-weight: bold;
    }

    .social a {
      display: inline-block;
      margin: 10px;
      color: #000;
      text-decoration: none;
      font-weight: bold;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: #111;
      font-size: 14px;
      color: #aaa;
    }

    /* Floating WhatsApp button */
    .whatsapp-float {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background-color: #25D366;
      color: #fff;
      border-radius: 50%;
      width: 60px;
      height: 60px;
      text-align: center;
      font-size: 30px;
      box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
      z-index: 1000;
    }

    .whatsapp-float:hover {
      background-color: #1ebe5d;
    }

    .whatsapp-float a {
      color: #fff;
      display: block;
      line-height: 60px;
      text-decoration: none;
    }

    /* Gallery styling */
    .gallery {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }

    .gallery img {
      width: 200px;
      border-radius: 15px;
      object-fit: cover;
    }

    /* Testimonials / About */
    .section-title {
      font-size: 28px;
      margin-bottom: 20px;
      letter-spacing: 1px;
    }

    @media screen and (max-width: 600px) {
      .gallery img {
        width: 100%;
      }
    }
  </style>
</head>

<body>

<header>
  <h1>Dream Empire</h1>
  <p>Luxury Beauty & Hair Brand</p>
</header>

<!-- Hero / About Section -->
<section>
  <div class="box">
    <h2 class="section-title">About Us</h2>
    <p>Dream Empire is your ultimate beauty destination. We offer professional nails, premium human hair, and wholesale products. Our goal is to make every client feel luxurious and confident.</p>
  </div>
</section>

<!-- Nails Section -->
<section>
