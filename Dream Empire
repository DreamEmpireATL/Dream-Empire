  </div>
</section>

<!-- Products / Wholesale Section -->
<section>
  <div class="box">
    <h2 class="section-title">Products & Wholesale</h2>
    <p>We sell hair and beauty products in bulk worldwide.</p>
    <div class="gallery">
      <!-- Mete imaj pwodwi yo la -->
      <img src="images/product1.jpg" alt="Product 1">
      <img src="images/product2.jpg" alt="Product 2">
      <img src="images/product3.jpg" alt="Product 3">
    </div>
  </div>
</section>

<!-- Contact Section -->
<section>
  <div class="box">
    <h2 class="section-title">Contact Us</h2>

    <a class="btn" href="tel:+16789749912">📞 Call Us</a>
    <a class="btn" href="https://wa.me/16789749912">💬 WhatsApp</a>

    <div class="social">
      <p>Follow us:</p>
      <a href="https://www.tiktok.com/@sucredor2.0?_r=1&_t=ZT-95Jpwf0NiPd" target="_blank">TikTok</a> |
      <a href="https://www.instagram.com/dream____nails___?igsh=MTNzMW1mcHFsaWprcA==" target="_blank">Instagram</a>
    </div>
  </div>
</section>

<!-- Payment Section -->
<section>
  <div class="box">
    <h2 class="section-title">Payment Methods</h2>
    <p>We accept:</p>
    <p>💵 Cash | 💳 Zelle | 📲 Cash App | 🌐 PayPal</p>
  </div>
</section>

<footer>
  © 2026 Dream Empire - All rights reserved
</footer>

<!-- Floating WhatsApp Button -->
<div class="whatsapp-float">
  <a href="https://wa.me/16789749912" target="_blank">💬</a>
</div>

</body>
</html>