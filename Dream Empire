    <h2 class="section-title">Dream Nails</h2>
    <p>Professional nail services with style & elegance.</p>
    <div class="gallery">
      <!-- Mete imaj ou yo la -->
      <img src="images/nail1.jpg" alt="Nail 1">
      <img src="images/nail2.jpg" alt="Nail 2">
      <img src="images/nail3.jpg" alt="Nail 3">
    </div>
  </div>
</section>

<!-- Hair Section -->
